rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() { return request.auth != null; }

    // Safely check if the current user is an Admin
    function isAdmin() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Safely check if the current user is Approved
    function isApproved() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true;
    }

    function isOwner(userId) { return request.auth.uid == userId; }

    // --- RULES ---

    match /users/{userId} {
      allow read: if isSignedIn();

      // NEW USER REGISTRATION:
      // A user can create their own document if they set isAdmin and isApproved to false.
      // This allows them to "seed" their profile so Admins can see and approve them.
      allow create: if isSignedIn() && isOwner(userId) &&
        request.resource.data.get('isAdmin', false) == false &&
        request.resource.data.get('isApproved', false) == false;

      // PROFILE UPDATES:
      // Admins can change anything (including approving users).
      // Owners can change their Name, Gender, Teams, etc., but cannot touch permission flags.
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwner(userId) &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'isApproved']))
      );

      allow delete: if isAdmin();
    }

    match /metadata/{document} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roster/{date} {
      // Must be approved or an admin to access the roster data
      allow read, write: if isApproved() || isAdmin();
    }

    match /thoughts/{thoughtId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.resource.data.userUid == request.auth.uid || isAdmin());

      allow update, delete: if isSignedIn() && (
        resource.data.userUid == request.auth.uid ||
        isAdmin() ||
        // Atomic Likes
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hearts', 'updatedAt']) &&
         request.resource.data.hearts.diff(resource.data.hearts).affectedKeys().hasOnly([request.auth.uid]))
      );
    }

    match /presence/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.resource.data.userUid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userUid == request.auth.uid;
    }
  }
}
