rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() { return request.auth != null; }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Checks permissions in BOTH Root Map and Sub-collection
    function isOrgAdmin(orgId) {
      return isSignedIn() && (
        // 1. Check Root Map (Transition)
        (getUserData().get('organisations', null) != null &&
         !(getUserData().organisations is list) &&
         getUserData().organisations.keys().hasAny([orgId]) &&
         getUserData().organisations[orgId].get('isAdmin', false) == true)
        ||
        // 2. Check Sub-collection (New Target)
        (exists(/databases/$(database)/documents/organisations/$(orgId)/memberships/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/organisations/$(orgId)/memberships/$(request.auth.uid)).data.get('isAdmin', false) == true)
      );
    }

    function isOrgApproved(orgId) {
      return isSignedIn() && (
        // 1. Check Root Map (Transition)
        (getUserData().get('organisations', null) != null &&
         !(getUserData().organisations is list) &&
         getUserData().organisations.keys().hasAny([orgId]) &&
         getUserData().organisations[orgId].get('isApproved', false) == true)
        ||
        // 2. Check Sub-collection (New Target)
        (exists(/databases/$(database)/documents/organisations/$(orgId)/memberships/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/organisations/$(orgId)/memberships/$(request.auth.uid)).data.get('isApproved', false) == true)
      );
    }

    function isOrgOwner(orgId) {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/organisations/$(orgId)) &&
             get(/databases/$(database)/documents/organisations/$(orgId)).data.get('ownerId', '') == request.auth.uid;
    }

    // --- RULES ---

    match /organisations/{orgId} {
      allow read: if isSignedIn();
      allow update: if isSignedIn() && (isOrgAdmin(orgId) || isOrgOwner(orgId));
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && isOrgOwner(orgId);

      match /memberships/{userId} {
        allow read: if isSignedIn() && (isOrgApproved(orgId) || request.auth.uid == userId);
        allow write: if isSignedIn() && (isOrgAdmin(orgId) || request.auth.uid == userId);
      }

      match /presence/{docId} {
        allow read: if isSignedIn() && isOrgApproved(orgId);
        allow create: if isSignedIn() && isOrgApproved(orgId) && request.resource.data.userUid == request.auth.uid;
        allow update, delete: if isSignedIn() && isOrgApproved(orgId) && resource.data.userUid == request.auth.uid;
      }

      match /{allPaths=**} {
        allow read: if isSignedIn() && isOrgApproved(orgId);
        allow write: if isSignedIn() && isOrgAdmin(orgId);
      }
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        request.auth.uid == userId ||
        getUserData().get('organisations', null) != null
      );
      allow delete: if isSignedIn() && getUserData().get('organisations', null) != null;
    }
  }
}
